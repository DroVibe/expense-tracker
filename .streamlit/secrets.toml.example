# SUPABASE SECRETS — Co-Parent Expense Tracker
# Copy this file to secrets.toml and fill in your values
# DO NOT commit secrets.toml to version control
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SUPABASE_URL = "https://your-project-id.supabase.co"
SUPABASE_KEY  = "your-anon-public-key-here"

# ── Access PIN ────────────────────────────────────────────────────────────────
# Both parents use the same PIN to unlock the app.
# Set this to a shared PIN only your family knows.
APP_PIN = "1234"
